# =================================
# Application Configuration
# =================================
APP_ENV=production
APP_NAME=chatgpt-creator
APP_PORT=8080
APP_MODE=release

# =================================
# Database Configuration
# =================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=chatgpt
DB_PASSWORD=chatgpt_secret_change_me
DB_NAME=chatgpt_creator
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m

# =================================
# Redis Configuration (Job Queue)
# =================================
REDIS_ENABLED=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =================================
# Frontend Configuration
# =================================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =================================
# Registration Configuration
# =================================
DEFAULT_PROXY=
DEFAULT_PASSWORD=
DEFAULT_DOMAIN=
WORKER_POOL_SIZE=5
REGISTRATION_TIMEOUT=10m
MAX_RETRIES=3

# =================================
# Email Domains Configuration
# =================================
EMAIL_DOMAINS_HEALTH_CHECK_ENABLED=true
EMAIL_DOMAINS_HEALTH_CHECK_INTERVAL=5m
EMAIL_DOMAINS_DEFAULT_SOURCE=generator

# =================================
# Logging Configuration
# =================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# =================================
# API Configuration
# =================================
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_DURATION=1m
API_READ_TIMEOUT=30s
API_WRITE_TIMEOUT=30s
API_SHUTDOWN_TIMEOUT=10s

# =================================
# WebSocket Configuration
# =================================
WS_ENABLED=true
WS_PING_INTERVAL=30s
WS_PONG_WAIT=60s
WS_MAX_MESSAGE_SIZE=4096

# =================================
# Frontend Build Configuration
# =================================
NEXT_PUBLIC_API_URL=http://localhost:8080
